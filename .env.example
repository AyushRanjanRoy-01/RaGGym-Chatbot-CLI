# ─────────────────────────────────────────────────────────────────────────────
# RAGGym configuration. Copy to `.env` and edit. Every layer is swappable here
# without touching code (validated at startup by pydantic-settings).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
# provider: ollama (local, default) | openai | anthropic
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
LLM_TEMPERATURE=0
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI is a co-equal option (better latency for live demos / interviews):
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-5.4-mini
# OPENAI_API_KEY=sk-...

# Anthropic (strong tutor/reviewer + vision):
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings ───────────────────────────────────────────────────────────────
# provider: ollama (default) | openai
# NOTE: the embedding model must be IDENTICAL at ingest time and query time.
# Changing it after ingestion requires a full re-ingest.
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
# OpenAI upgrade path: EMBED_PROVIDER=openai, EMBED_MODEL=text-embedding-3-small

# ── Vector store ─────────────────────────────────────────────────────────────
# vector_store: qdrant (default, local in-process — no Docker) | chroma
VECTOR_STORE=qdrant
QDRANT_COLLECTION=raggym
# Use a separate collection per embedding model, e.g. raggym_openai for OpenAI.
# Leave QDRANT_URL empty for local on-disk mode; set it to use a Qdrant server:
# QDRANT_URL=http://localhost:6333

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
USE_HYBRID=true
USE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-base
USE_MULTI_QUERY=false

# ── Vision / figure captioning (Phase 1+, off by default) ───────────────────
ENABLE_CAPTIONING=false
VISION_PROVIDER=ollama
VISION_MODEL=llava

# ── Paths ────────────────────────────────────────────────────────────────────
DATA_DIR=./data
BOOKS_DIR=./data/books
VECTORSTORE_DIR=./vectorstore
WORKSPACE_DIR=./workspace

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# log_json=true for machine-parseable JSON logs; false for pretty console logs
LOG_JSON=false

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=dev

# ── Mode ─────────────────────────────────────────────────────────────────────
# local → fastembed + on-disk Qdrant + console logs, no cloud/auth ($0, default)
# cloud → Supabase (pgvector) + Azure + OpenTelemetry/Langfuse + auth
RAGGYM_MODE=local

# ── Cloud LLM — Azure OpenAI credentials (cloud mode) ────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Cloud data — Supabase credentials (cloud mode) ───────────────────────────
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_KEY=...
# SUPABASE_DB_URL=postgresql://postgres:<pw>@<host>:5432/postgres

# ── Observability (cloud mode) ───────────────────────────────────────────────
# OTEL_ENABLED=true
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
