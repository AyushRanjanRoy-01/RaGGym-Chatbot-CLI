# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: ollama | openai
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI (set LLM_PROVIDER=openai to activate) ─────────────────────────────
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ── Embeddings ────────────────────────────────────────────────────────────────
# Provider: ollama | openai
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768

# OpenAI embeddings alternative:
# EMBED_PROVIDER=openai
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIMS=1536

# ── Vector Store ──────────────────────────────────────────────────────────────
# Backend: qdrant | chroma
VECTOR_STORE=qdrant
COLLECTION_NAME=financial_docs

# Qdrant local (default — no Docker needed)
QDRANT_PATH=./vectorstore

# Qdrant remote / Qdrant Cloud (uncomment to use)
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-api-key

# ChromaDB fallback
CHROMA_PATH=./vectorstore

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5

# ── App ───────────────────────────────────────────────────────────────────────
APP_TITLE=Financial RAG Assistant
APP_DESCRIPTION=Ask questions about your financial documents.
