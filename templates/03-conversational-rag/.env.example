# LLM: openai (default) | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
# Ollama backup: LLM_PROVIDER=ollama / LLM_MODEL=llama3.2:3b / OLLAMA_BASE_URL=http://localhost:11434

# Embeddings: openai (default) | ollama
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small
# Ollama backup: EMBED_PROVIDER=ollama / EMBED_MODEL=nomic-embed-text

# Vector store: qdrant (default) | chroma
VECTOR_STORE=qdrant
