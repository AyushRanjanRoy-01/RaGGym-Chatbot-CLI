# LLM provider: "openai" (default) or "ollama"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Embedding provider: "openai" (default) or "ollama"
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small

# Vector store: "qdrant" (default) or "chroma"
VECTOR_STORE=qdrant

# Ollama backup (set LLM_PROVIDER=ollama and EMBED_PROVIDER=ollama to use)
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2:3b
# EMBED_MODEL=nomic-embed-text
